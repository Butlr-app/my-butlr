{
  "expo": {
    "name": "My Butlr Guest",
    "slug": "my-butlr-guest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mybutlrguest",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F6F1E9",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.mybutlr.guest",
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:mybutlr.com"
      ]
    },
    "android": {
      "package": "com.mybutlr.guest",
      "adaptiveIcon": {
        "backgroundColor": "#071A2F",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "mybutlr.com",
              "pathPrefix": "/guest/stay"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#071A2F",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
