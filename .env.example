VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Edge Function secrets (never expose with a VITE_ prefix)
RESEND_API_KEY=
RESEND_FROM_EMAIL=My Butlr <signatures@example.com>
APP_URL=http://localhost:5173
SIGNING_TOKEN_SECRET=
SIGNING_OTP_PEPPER=
# Use "log" locally and "resend" in production.
SIGNING_EMAIL_MODE=log

# Edge Function: send-contract-email (set in Supabase secrets, not Vite)
# CONTRACT_FROM_EMAIL=My Butlr <contracts@mybutlr.com>
# APP_ORIGIN=https://app.mybutlr.com

# Contract PDF/image analysis through the authenticated contract-vision Edge Function.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_CHAT_MODEL=gpt-4.1-mini
